{
    // ===== B01_1 雜賀孫市狙擊訓練場地圖 =====
    // 專為狙擊訓練設計的開放式地形
    "Path": [
        {
            "Name": "training_path",  // 改走正方形路徑（debug 用）
            "Points": ["square_nw", "square_ne", "square_se", "square_sw", "square_nw"]
        },
        {
            "Name": "circle_path",    // 環形移動路線（用於移動目標練習）
            "Points": ["target_1000", "circle_1", "circle_2", "circle_3", "circle_4", "target_1000"]
        }
    ],
    
    // ===== 訓練用小兵定義 =====
    "Creep": [
        {
            "Name": "practice_dummy",
            "Label": "練習假人",
            "DefendPhysic": 0,
            "DefendMagic": 0,
            "HP": 100,                    // 低血量，容易擊殺（已調為 2x）
            "MoveSpeed": 0,               // 靜止不動
            "coins": 5                    // 少量獎勵
        },
        {
            "Name": "moving_target",
            "Label": "移動靶",
            "DefendPhysic": 0,
            "DefendMagic": 0,
            "HP": 150,                    // 已調為 2x
            "MoveSpeed": 150,             // 中等移速
            "coins": 8
        },
        {
            "Name": "training_creep",
            "Label": "訓練小兵",
            "DefendPhysic": 1,
            "DefendMagic": 0,
            "HP": 200,                    // 已調為 2x
            "MoveSpeed": 200,
            "coins": 12
        },
        {
            "Name": "armored_dummy",
            "Label": "裝甲假人",
            "DefendPhysic": 5,
            "DefendMagic": 2,
            "HP": 400,                    // 已調為 2x
            "MoveSpeed": 50,
            "coins": 20
        }
    ],
    
    // ===== 檢查點定義 =====
    // 訓練場的關鍵位置點
    "CheckPoint": [
        {"Name": "player_start", "Class": "Start", "X": 0, "Y": 0},           // 玩家起始位置
        {"Name": "creep_spawn", "Class": "CreepSpawn", "X": 200, "Y": 100},   // 小兵生成點
        
        // 距離測試點（用於不同射程練習）
        {"Name": "target_800", "Class": "Target", "X": 800, "Y": 0},          // 800距離標記
        {"Name": "target_1000", "Class": "Target", "X": 1000, "Y": 0},        // 1000距離標記
        {"Name": "target_1200", "Class": "Target", "X": 1200, "Y": 0},        // 1200距離標記
        {"Name": "target_1600", "Class": "Target", "X": 1600, "Y": 0},        // 1600距離標記（雜賀最遠射程）
        
        // 環形移動路徑點（用於移動目標練習）
        {"Name": "circle_1", "Class": "MovePath", "X": 1100, "Y": 100},
        {"Name": "circle_2", "Class": "MovePath", "X": 1100, "Y": -100},
        {"Name": "circle_3", "Class": "MovePath", "X": 900, "Y": -100},
        {"Name": "circle_4", "Class": "MovePath", "X": 900, "Y": 100},

        // 正方形路徑四角（training_path 使用，中心 (800,0)，邊長 800）
        {"Name": "square_nw", "Class": "MovePath", "X": 400,  "Y": 400},
        {"Name": "square_ne", "Class": "MovePath", "X": 1200, "Y": 400},
        {"Name": "square_se", "Class": "MovePath", "X": 1200, "Y": -400},
        {"Name": "square_sw", "Class": "MovePath", "X": 400,  "Y": -400},
        
        // 特殊測試區域
        {"Name": "boss_area", "Class": "BossArea", "X": 1400, "Y": 200},      // Boss戰區域
        {"Name": "safe_zone", "Class": "SafeZone", "X": -100, "Y": 0},        // 安全區域
        {"Name": "item_shop", "Class": "Shop", "X": -50, "Y": 50}             // 道具商店
    ],
    
    // ===== 防禦塔定義 =====
    // 訓練場不需要可建造塔，僅作為環境元素
    "Tower": [
        {
            "Name": "target_tower",       // 目標塔（用作射擊目標）
            "Property": {
                "Hp": 500,
                "Block": 0                 // 不阻擋移動
            },
            "Attack": {
                "Range": 0,               // 不攻擊
                "AttackSpeed": 0,
                "Physic": 0,
                "Magic": 0,
                "cost": 0                 // 無法建造
            }
        },
        {
            "Name": "practice_tower",     // 練習塔（可攻擊的目標）
            "Property": {
                "Hp": 800,
                "Block": 0
            },
            "Attack": {
                "Range": 0,
                "AttackSpeed": 0,
                "Physic": 0,
                "Magic": 0,
                "cost": 0
            }
        }
    ],
    
    // ===== 訓練波次配置 =====
    // 針對不同關卡設計的小兵波次
    "CreepWave": [
        {
            "Name": "S0_LastHit_Wave",    // S0關卡：遠距補刀
            "StartTime": 3,
            "Detail": [
                {
                    "Path": "training_path",
                    "Creeps": [
                        // 定期生成練習假人
                        {"Time": 0, "Creep": "armored_dummy"},
                        {"Time": 10, "Creep": "training_creep"},
                        {"Time": 20, "Creep": "armored_dummy"},
                        {"Time": 30, "Creep": "training_creep"}
                    ]
                }
            ]
        },
        {
            "Name": "S1b_MovingTarget_Wave", // S1b關卡：移動目標
            "StartTime": 200,
            "Detail": [
                {
                    "Path": "circle_path",
                    "Creeps": [
                        {"Time": 0, "Creep": "moving_target"},
                        {"Time": 8, "Creep": "moving_target"},
                        {"Time": 16, "Creep": "moving_target"}
                    ]
                }
            ]
        },
        {
            "Name": "S6_ArmorTest_Wave",      // S6關卡：破甲測試
            "StartTime": 500,
            "Detail": [
                {
                    "Path": "training_path",
                    "Creeps": [
                        {"Time": 0, "Creep": "armored_dummy"},
                        {"Time": 10, "Creep": "armored_dummy"}
                    ]
                }
            ]
        }
    ]
}